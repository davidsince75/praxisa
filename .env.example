# ============================================================
# .env.example — secret reference names only, NO real values
# All values are stored in Doppler (stg / production configs)
# Copy this file to .env for local dev and populate manually
# .env is gitignored — never commit real secrets
# ============================================================

# Database (PgBouncer connection string)
DATABASE_URL=

# Redis
REDIS_URL=

# JWT signing keys (base64-encoded PEM)
JWT_SIGNING_KEY=
JWT_SIGNING_KEY_PUBLIC=

# Mistral AI
MISTRAL_API_KEY=

# GoCardless
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=sandbox   # sandbox | live

# Brevo (transactional email)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Cloudflare R2 (object storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# App config
NODE_ENV=development             # development | staging | production
PORT=3000
API_BASE_URL=http://localhost:3000
LOG_LEVEL=debug                  # debug | info | warn | error

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
