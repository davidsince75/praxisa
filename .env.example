# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.
#
# Quick start (local dev with docker-compose up -d):
#   1. Generate JWT keys:
#        openssl genpkey -algorithm ed25519 -out /tmp/jwt_priv.pem
#        openssl pkey -in /tmp/jwt_priv.pem -pubout -out /tmp/jwt_pub.pem
#   2. Base64-encode them:
#        base64 -w0 /tmp/jwt_priv.pem   → JWT_SIGNING_KEY
#        base64 -w0 /tmp/jwt_pub.pem    → JWT_SIGNING_KEY_PUBLIC

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# ── Database (matches docker-compose.yml) ─────────────────────────────────────
DATABASE_URL=postgresql://praxisa:praxisa_dev_password@localhost:5432/praxisa_dev

# ── Redis (matches docker-compose.yml) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (Ed25519 keys, base64-encoded PEM) ────────────────────────────────────
JWT_SIGNING_KEY=
JWT_SIGNING_KEY_PUBLIC=

# ── Email (Mailpit for local dev — no real sending) ───────────────────────────
# View caught mail at http://localhost:8025
BREVO_API_KEY=local-dev-key
BREVO_SENDER_EMAIL=noreply@praxisa.fr
BREVO_SENDER_NAME=Praxisa

# ── Workers only ──────────────────────────────────────────────────────────────
ADMIN_ALERT_EMAIL=admin@praxisa.fr

# ── AI (optional — AI features disabled if absent) ────────────────────────────
# MISTRAL_API_KEY=
