{
  "name": "praxisa-platform",
  "private": true,
  "version": "0.0.1",
  "description": "Praxisa platform — modular monolith, EU-first, GDPR-by-design",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @praxisa/api dev",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "audit:deps": "pnpm audit --audit-level=high",
    "audit:secrets": "trufflehog filesystem . --only-verified",
    "db:generate": "pnpm --filter @praxisa/api db:generate",
    "db:migrate": "pnpm --filter @praxisa/api db:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-boundaries": "^4.2.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.29.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  }
}
